  "the-project-name": "Starter",
  "scripts": {
    "prod": "webpack --env NODE_ENV=production --env production",
    "prod:watch": "webpack --env NODE_ENV=production --env production --watch",
    "dev": "webpack --env NODE_ENV=development",
    "dev:watch": "webpack --env NODE_ENV=development --watch",
    "eslint": "eslint _src/js/**/*.js",
    "eslint:fix": "eslint _src/js/**/*.js --fix",
    "stylelint": "stylelint _src/**/**/*.{css,scss,pcss}",
    "stylelint:fix": "stylelint _src/**/**/*.{css,scss,pcss} --fix",
    "translate": "wp-pot --src '**/**/**/*.php' --dest-file 'languages/starter.pot' --package 'Starter' --domain 'starter' --last-translator 'Hypercrew'"
  },
  "babel": {
    "extends": "./config/babel.config.js"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "body-scroll-lock": "^4.0.0-beta.0",
